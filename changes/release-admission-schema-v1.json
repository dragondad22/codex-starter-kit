{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dragondad22/codex-starter-kit/changes/release-admission-schema-v1.json",
  "title": "Codex Starter Kit release admission",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "version", "milestone", "release_issue", "approved_by", "records"],
  "properties": {
    "schema_version": {"const": 1},
    "version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"},
    "milestone": {"type": "string", "minLength": 1},
    "release_issue": {"type": "integer", "minimum": 1},
    "approved_by": {"type": "string", "minLength": 1},
    "records": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
    }
  }
}
