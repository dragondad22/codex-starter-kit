{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Starter Kit change record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "summary",
    "category",
    "audiences",
    "components",
    "issues",
    "breaking",
    "internal_only"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "summary": {"type": "string", "minLength": 1},
    "category": {
      "enum": ["added", "changed", "deprecated", "removed", "fixed", "security"]
    },
    "audiences": {
      "type": "array",
      "uniqueItems": true,
      "items": {"enum": ["users", "operators", "developers", "stakeholders", "security"]}
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
    },
    "issues": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1}
    },
    "pull_requests": {
      "type": "array",
      "items": {"type": "integer", "minimum": 1}
    },
    "breaking": {"type": "boolean"},
    "internal_only": {"type": "boolean"},
    "internal_disposition": {"type": "string", "minLength": 1}
  },
  "allOf": [
    {
      "if": {"properties": {"internal_only": {"const": true}}},
      "then": {
        "required": ["internal_disposition"],
        "properties": {"audiences": {"maxItems": 0}}
      },
      "else": {
        "properties": {"audiences": {"minItems": 1}},
        "not": {"required": ["internal_disposition"]}
      }
    },
    {
      "anyOf": [
        {"properties": {"issues": {"minItems": 1}}},
        {"required": ["pull_requests"], "properties": {"pull_requests": {"minItems": 1}}}
      ]
    }
  ]
}
